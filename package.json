{
  "name": "tampermonkey-scripts",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.js",
    "build:watch": "node build.js --watch",
    "lint": "eslint scripts/**/src/**/*.ts",
    "lint:fix": "eslint scripts/**/src/**/*.ts --fix",
    "format": "prettier --write scripts/**/src/**/*.ts",
    "format:check": "prettier --check scripts/**/src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/tampermonkey": "^5.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "glob": "^11.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.8.0"
  },
  "lint-staged": {
    "scripts/**/src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "tampermonkey-scripts": "file:",
    "typescript-eslint": "^8.58.2"
  }
}
