{
  "name": "tampermonkey-scripts",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "scripts/lookmovie2.to"
  ],
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/lnorton89/tampermonkey-scripts.git"
  },
  "scripts": {
    "build": "node build.js",
    "build:watch": "node build.js --watch",
    "lint": "eslint \"scripts/**/src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"scripts/**/src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"scripts/**/src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"scripts/**/src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/tampermonkey": "^5.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "glob": "^11.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.8.0"
  },
  "lint-staged": {
    "scripts/**/src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "tampermonkey-scripts": "file:",
    "typescript-eslint": "^8.58.2"
  }
}
