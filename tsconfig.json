{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "outDir": ".tsc-out",
    "rootDir": "."
  },
  "include": ["scripts/**/src/**/*.ts", "build.js"],
  "exclude": ["node_modules"]
}
